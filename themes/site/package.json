{
  "name": "site",
  "version": "3.0.0",
  "description": "Webサイト制作プロジェクト",
  "keywords": [
    "CMS",
    "a-blog cms"
  ],
  "browserslist": [
    "defaults",
    "safari >= 15.4"
  ],
  "config": {
    "local": "localhost",
    "theme": "site"
  },
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "webpack --mode production --config webpack.prod.js",
    "dev": "webpack --watch --mode development --config webpack.dev.js",
    "start": "webpack-cli serve --mode development --config webpack.dev.js",
    "analyze": "webpack --mode production --config webpack.analyze.js",
    "check-update": "npx -p npm-check-updates -c \"ncu -u\""
  },
  "author": "appleple",
  "license": "MIT",
  "dependencies": {
    "dom-content-loaded": "^1.0.2",
    "stylelint-config-recess-order": "^7.3.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.0",
    "@babel/core": "^7.28.0",
    "@babel/eslint-parser": "^7.28.0",
    "@babel/eslint-plugin": "^7.27.1",
    "@babel/preset-env": "^7.28.0",
    "autoprefixer": "^10.4.21",
    "babel-loader": "^10.0.0",
    "core-js": "^3.44.0",
    "css-loader": "^7.1.2",
    "eslint": "^8.57.1",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-import-resolver-webpack": "^0.13.10",
    "eslint-webpack-plugin": "^5.0.2",
    "mini-css-extract-plugin": "^2.9.2",
    "postcss": "^8.5.6",
    "postcss-loader": "^8.1.1",
    "sass": "^1.89.2",
    "sass-loader": "^16.0.5",
    "stylelint": "^16.22.0",
    "stylelint-config-recommended": "^16.0.0",
    "stylelint-config-standard-scss": "^15.0.1",
    "stylelint-webpack-plugin": "^5.0.1",
    "webpack": "^5.100.2",
    "webpack-bundle-analyzer": "^4.10.2",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2",
    "webpack-fix-style-only-entries": "^0.6.1",
    "webpack-merge": "^6.0.1",
    "webpack-remove-empty-scripts": "^1.1.1"
  }
}
